{
  "name": "acc-assist",
  "version": "1.0.0",
  "description": "ACC Assist desktop agent for secure accounting analytics on SQL Server",
  "main": "./out/main/index.js",
  "author": "ACC Assist Team",
  "homepage": "https://accassist.app",
  "license": "UNLICENSED",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "smoke:agent:fast": "tsx scripts/smoke-agent-orchestrator.ts --mode=fast",
    "smoke:agent:full": "tsx scripts/smoke-agent-orchestrator.ts --mode=full",
    "smoke:agent": "npm run smoke:agent:full",
    "smoke:fast": "npm run build && npm run smoke:agent:fast",
    "smoke:full": "npm run build && npm run smoke:agent:full",
    "smoke": "npm run smoke:full",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "test:integration": "tsx --test tests/integration/**/*.test.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:golden": "tsx scripts/ops/goldenPromptHarness.ts",
    "eval:metrics": "tsx scripts/ops/goldenMetricEval.ts",
    "shadow:report": "tsx scripts/ops/shadow-mismatch-report.ts",
    "engine:monitor": "tsx scripts/ops/engine-monitor.ts",
    "smoke:prompt-transport": "tsx scripts/ops/promptTransportSmoke.ts",
    "validate:connector:live": "tsx scripts/validate-connector-live.ts",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "remote:status": "pwsh -ExecutionPolicy Bypass -File scripts/ops/remote-server-control.ps1 -Action status",
    "remote:install": "pwsh -ExecutionPolicy Bypass -File scripts/ops/remote-server-control.ps1 -Action install",
    "remote:uninstall": "pwsh -ExecutionPolicy Bypass -File scripts/ops/remote-server-control.ps1 -Action uninstall",
    "remote:start": "pwsh -ExecutionPolicy Bypass -File scripts/ops/remote-server-control.ps1 -Action start",
    "remote:stop": "pwsh -ExecutionPolicy Bypass -File scripts/ops/remote-server-control.ps1 -Action stop",
    "remote:restart": "pwsh -ExecutionPolicy Bypass -File scripts/ops/remote-server-control.ps1 -Action restart",
    "remote:autoconfig-sql": "pwsh -ExecutionPolicy Bypass -File scripts/ops/remote-server-control.ps1 -Action autoconfig-sql",
    "remote:logs": "pwsh -ExecutionPolicy Bypass -File scripts/ops/remote-server-control.ps1 -Action logs",
    "remote:ask-ai": "pwsh -ExecutionPolicy Bypass -File scripts/ops/remote-server-control.ps1 -Action ask-ai",
    "smoke:live:agent": "pwsh -ExecutionPolicy Bypass -File scripts/ops/smoke-live-agent.ps1",
    "smoke:live:agent:allow-failure": "pwsh -ExecutionPolicy Bypass -File scripts/ops/smoke-live-agent.ps1 -AllowFailure",
    "release:readiness": "node scripts/ops/release-readiness.mjs",
    "release:readiness:strict": "node scripts/ops/release-readiness.mjs --strict-signing",
    "release:version:patch": "npm version patch --no-git-tag-version",
    "release:version:minor": "npm version minor --no-git-tag-version",
    "release:version:major": "npm version major --no-git-tag-version",
    "release:version:beta": "npm version prerelease --preid=beta --no-git-tag-version",
    "release:version:rc": "npm version prerelease --preid=rc --no-git-tag-version",
    "release:rollback": "pwsh -ExecutionPolicy Bypass -File scripts/ops/rollback-release.ps1"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.6.2",
    "mssql": "^12.5.4",
    "node-sql-parser": "^5.4.0",
    "ssh2": "^1.17.0",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "app-builder-bin": "^5.0.0-alpha.13",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
